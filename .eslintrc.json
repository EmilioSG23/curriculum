{
	"root": true,
	"overrides": [
		{
			"files": ["*.ts", "*.tsx", "*.astro"],
			"parser": "@typescript-eslint/parser",
			"parserOptions": {
				"project": "./tsconfig.json",
				"sourceType": "module"
			},
			"plugins": ["@typescript-eslint", "astro"],
			"extends": ["plugin:@typescript-eslint/recommended", "plugin:astro/recommended"],
			"rules": {}
		},
		{
			"files": ["*.js"],
			"extends": ["./node_modules/standard/eslintrc.json"]
		}
	]
}
