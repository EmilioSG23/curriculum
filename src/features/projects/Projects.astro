---
import ProjectItem from "@/features/projects/ProjectItem.astro";
import { useT } from "@/i18n/utils";
import Section from "@/components/sections/Section.astro";
import { PROJECTS } from "@/data/projects";
const t = useT();
---

<Section id="projects">
	<div class="flex justify-center 2xl:w-[125%] my-5 mt-20">
		<div class="flex flex-wrap justify-center w-full xl:gap-x-3 2xl:gap-x-5">
			{
				PROJECTS.map(
					({ id, name, link, download, github, description, technologies, uses }, index) => (
						<ProjectItem
							index={index}
							id={id}
							name={name}
							download={download}
							link={link}
							github={github}
							description={description}
							technologies={technologies}
							uses={uses}
						/>
					),
				)
			}
		</div>
	</div>
</Section>

<script>
	// Índices del proyecto cuya descripción o tecnología está activa en modo táctil.
	// -1 significa que ninguno está activo.
	let activeLanguageIndex = -1;
	let activeDescriptionIndex = -1;

	/**
	 * Calcula las clases de delay para la animación de entrada de cada tarjeta de proyecto.
	 * Escalone las tarjetas con delays distintos según el número de columnas por breakpoint:
	 * - Base (1 col): sin delay.
	 * - md (2 cols): alterna delay-0 / delay-150.
	 * - lg (3 cols): rota entre delay-0 / delay-150 / delay-300.
	 */
	function delayClass(index: number): string {
		const base = "delay-0";

		const mdIndex = index % 2;
		const md = mdIndex === 0 ? "md:delay-0" : "md:delay-150";

		const lgIndex = index % 3;
		const lg = lgIndex === 0 ? "lg:delay-0" : lgIndex === 1 ? "lg:delay-150" : "lg:delay-300";

		return `${base} ${md} ${lg}`;
	}

	/** Aplica las clases de delay calculadas a cada artículo de proyecto en el DOM. */
	function applyDelayClass() {
		const $projectArticles = document.querySelectorAll("article.project-item");

		$projectArticles.forEach((projectArticle, index) => {
			projectArticle.classList.add(...delayClass(index).split(" "));
		});
	}

	/**
	 * Configura la interactividad táctil de los proyectos.
	 * En dispositivos con puntero fino (ratón) se omite porque el hover de CSS ya gestiona
	 * la visibilidad de la descripción y los iconos.
	 * En táctil, un tap en el botón info alterna la descripción visible y
	 * un tap en la imagen de tecnología muestra su nombre.
	 */
	function setupProjectInteractions() {
		if (window.matchMedia("(pointer: fine)").matches) return;

		const descriptionButtons = Array.from(
			document.querySelectorAll<HTMLButtonElement>("[data-project-info-button]"),
		);
		const descriptionProjects = Array.from(
			document.querySelectorAll<HTMLElement>("div[id$='-description']"),
		);
		const descriptionImages = Array.from(
			document.querySelectorAll<HTMLElement>("img[id$='-image']"),
		);
		const languageProjects = Array.from(
			document.querySelectorAll<HTMLElement>("[data-language-project]"),
		);
		const languageNames = Array.from(
			document.querySelectorAll<HTMLElement>("[data-language-span-content]"),
		);
		const languageArrows = Array.from(
			document.querySelectorAll<HTMLElement>("[data-language-span-arrow]"),
		);

		descriptionButtons.forEach((button, index) => {
			// Hace visible el botón en modo táctil (en desktop está oculto por defecto).
			button.classList.remove("hidden");
			button.onclick = () => {
				descriptionProjects.forEach((description, currentIndex) => {
					// Activa solo la descripción del proyecto clicado; desactiva las demás.
					const isCurrent = currentIndex === index && activeDescriptionIndex !== index;
					description.classList.toggle("opacity-100", isCurrent);
					description.classList.toggle("pointer-events-auto", isCurrent);
					descriptionImages[currentIndex]?.classList.toggle("scale-110", isCurrent);
				});

				// Guarda el índice activo; si se vuelve a clicar el mismo, lo desactiva (-1 → ninguno).
				activeDescriptionIndex = activeDescriptionIndex === index ? -1 : index;
			};
		});

		languageProjects.forEach((image, index) => {
			image.onclick = () => {
				// Alterna la visibilidad de la flecha y el nombre de la tecnología seleccionada.
				const nextIndex = activeLanguageIndex === index ? -1 : index;
				languageArrows.forEach((arrow, currentIndex) => {
					arrow.classList.toggle("opacity-100", currentIndex === nextIndex);
				});
				languageNames.forEach((name, currentIndex) => {
					name.classList.toggle("opacity-100", currentIndex === nextIndex);
				});
				activeLanguageIndex = nextIndex;
			};
		});
	}

	/** Punto de entrada: aplica delays de animación y configura la interactividad táctil. */
	function initProjects() {
		applyDelayClass();
		setupProjectInteractions();
	}

	document.addEventListener("DOMContentLoaded", initProjects, { once: true });
</script>
