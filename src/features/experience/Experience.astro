---
import ExperienceItem from "@/features/experience/ExperienceItem.astro";
import Recognitions from "@/features/experience/Recognitions.astro";
import Arrow from "@/components/sections/Arrow.astro";
import HeaderSection from "@/components/sections/HeaderSection.astro";
import { useT } from "@/i18n/utils";
import { EXPERIENCE } from "@/features/experience/data";
import Section from "@/components/sections/Section.astro";

const t = useT();
---

<Section id="experience">
	<div class="relative w-full max-w-4xl">
		<div
			id="experience-list"
			class="flex flex-col items-center w-full gap-5 mt-10 collapsed overflow-hidden transition-all p-6"
		>
			{
				EXPERIENCE.map(({ place, position, time, description }, index) => (
					<ExperienceItem
						index={index}
						place={place}
						position={position}
						time={time}
						description={description}
					/>
				))
			}
		</div>
		<div
			id="experience-list-fade"
			class="absolute h-25 w-full bottom-0 left-0 bg-gradient-to-b from-transparent to-background pointer-events-none"
		>
		</div>
	</div>
	<button
		id="btn-experience-list-collapse"
		type="button"
		aria-controls="experience-list"
		aria-expanded="false"
		class="mt-5 2xl:w-1/6 xl:w-1/4 lg:w-1/3 sm:w-1/2 w-full
			flex items-center justify-center text-sm text-neon border border-neon rounded px-4 py-2
			hover:bg-hover transition cursor-pointer"
	>
		<div class="flex items-center gap-2">
			<svg
				id="experience-arrow"
				class="size-6 text-neon -rotate-90"
				viewBox="0 0 24 24"
				fill="none"
				aria-hidden="true"
			>
				<path
					d="M16.1795 3.26875C15.7889 2.87823 15.1558 2.87823 14.7652 3.26875L8.12078 9.91322C6.94952 11.0845 6.94916 12.9833 8.11996 14.155L14.6903 20.7304C15.0808 21.121 15.714 21.121 16.1045 20.7304C16.495 20.3399 16.495 19.7067 16.1045 19.3162L9.53246 12.7442C9.14194 12.3536 9.14194 11.7205 9.53246 11.33L16.1795 4.68297C16.57 4.29244 16.57 3.65928 16.1795 3.26875Z"
					fill="currentColor"></path>
			</svg>
		</div>
		<span id="span-btn-experience-list"> Mostrar más </span>
	</button>
	<Recognitions />
</Section>

<style>
	#experience-list {
		transition: max-height 0.5s linear;
	}
	#experience-list.collapsed {
		max-height: 600px;
		overflow: hidden;
	}
	#experience-list.non-collapsed {
		max-height: max-content;
		overflow: visible;
	}
</style>

<script>
	// Estado del colapso de la lista de experiencias (true = colapsada por defecto).
	let collapsedList: boolean = true;

	/**
	 * Calcula las clases de delay para la animación de entrada de cada ítem de experiencia.
	 * El orden es inverso al de Projects para que las tarjetas entren desde el lado opuesto:
	 * - md (2 cols): par→delay-150, impar→delay-0.
	 * - lg (3 cols): primero→delay-300, segundo→delay-150, tercero→delay-0.
	 */
	function delayClass(index: number): string {
		const base = "delay-0";

		const mdIndex = index % 2;
		const md = mdIndex === 0 ? "md:delay-150" : "md:delay-0";

		const lgIndex = index % 3;
		const lg = lgIndex === 0 ? "lg:delay-300" : lgIndex === 1 ? "lg:delay-150" : "lg:delay-0";

		return `${base} ${md} ${lg}`;
	}

	/** Aplica clases de delay calculadas a cada div de experiencia en el DOM. */
	function applyDelayClass() {
		const $experienceArticles = document.querySelectorAll("div.experience-item");

		$experienceArticles.forEach((experience, index) => {
			experience.classList.add(...delayClass(index).split(" "));
		});
	}

	/**
	 * Actualiza el texto del botón "Mostrar más/menos" según el idioma activo y el estado actual.
	 * Lee el idioma directamente del atributo lang del <html> para sincronizarse con el toggle.
	 */
	function updateToggleButtonText() {
		const $span = document.querySelector("#span-btn-experience-list");
		const lang = document.documentElement.lang || "en";
		const isCollapsed = collapsedList;

		if ($span && lang == "es" && !isCollapsed) {
			$span.textContent = "Mostrar menos";
		}
		if ($span && lang == "es" && isCollapsed) {
			$span.textContent = "Mostrar más";
		}
		if ($span && lang == "en" && !isCollapsed) {
			$span.textContent = "Show less";
		}
		if ($span && lang == "en" && isCollapsed) {
			$span.textContent = "Show more";
		}
	}

	/**
	 * Alterna el estado expandido/colapsado de la lista de experiencias.
	 * Actualiza las clases CSS del contenedor, el degradado de fade, la flecha del botón
	 * y el atributo aria-expanded para accesibilidad.
	 */
	function toggleCollapse() {
		const $containerList = document.querySelector("#experience-list");
		const $fade = document.querySelector("#experience-list-fade");
		const $arrow = document.querySelector("#experience-arrow");
		if (!$containerList) return;

		if (collapsedList) {
			$containerList.classList.remove("collapsed");
			$containerList.classList.add("non-collapsed");
			$fade?.classList.add("hidden");
			$fade?.classList.remove("block");
			$arrow?.classList.add("rotate-90");
			$arrow?.classList.remove("-rotate-90");
			collapsedList = false;
		} else {
			$containerList.classList.add("collapsed");
			$containerList.classList.remove("non-collapsed");
			$fade?.classList.remove("hidden");
			$fade?.classList.add("block");
			$arrow?.classList.remove("rotate-90");
			$arrow?.classList.add("-rotate-90");
			collapsedList = true;
		}
		(
			document.querySelector("#btn-experience-list-collapse") as HTMLButtonElement | null
		)?.setAttribute("aria-expanded", String(!collapsedList));
		updateToggleButtonText();
	}

	document.addEventListener("DOMContentLoaded", () => {
		applyDelayClass();
		updateToggleButtonText();

		const $btnCollapse = document.querySelector("#btn-experience-list-collapse");
		if ($btnCollapse) {
			$btnCollapse.addEventListener("click", (e) => {
				e.preventDefault();
				toggleCollapse();
			});
		}
	});

	// Actualiza el texto del botón al cambiar de idioma (evento emitido por LanguageToggleButton).
	document.addEventListener("languagechange", (event: any) => {
		updateToggleButtonText();
	});
</script>
