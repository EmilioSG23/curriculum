---
import Carrousel from "@/components/Carrousel.astro";
import ImageModal from "@/components/modals/ImageModal.astro";
import { RECOGNITIONS } from "@/features/experience/data";
import RecognitionItem from "@/features/experience/RecognitionItem.astro";
import { useT } from "@/i18n/utils";

const t = useT();
---

<div class="w-full max-w-4xl mt-12">
	<!-- Cabecera con separador -->
	<div class="flex items-center gap-4 mb-6 px-2" data-aos="fade">
		<div class="h-px flex-1 bg-neon opacity-30"></div>
		<h2
			class="font-main text-[18px] sm:text-[20px] font-bold text-neon uppercase tracking-widest"
			data-translate="experience.recognitions.title"
		>
			{t("experience.recognitions.title")}
		</h2>
		<div class="h-px flex-1 bg-neon opacity-30"></div>
	</div>

	<Carrousel id="recognitions" itemHalfWidth="9rem">
		{
			RECOGNITIONS.map(({ image, titleKey, issuerKey, dateKey }) => (
				<div class="snap-center shrink-0 w-[min(300px,_calc(100%-1rem))] sm:w-72">
					<RecognitionItem
						image={image}
						titleKey={titleKey}
						issuerKey={issuerKey}
						dateKey={dateKey}
					/>
				</div>
			))
		}
	</Carrousel>
</div>

<ImageModal id="rec-recognition-modal" triggerAttr="data-rec-image" titleAttr="data-rec-title" />
