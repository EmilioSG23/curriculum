---
import { useT } from "@/i18n/utils";

const t = useT();
const { image, titleKey, issuerKey, dateKey } = Astro.props;
---

<button
	type="button"
	class="recognition-card group flex flex-col rounded-lg overflow-hidden border bg-background cursor-pointer w-full h-full text-left"
	data-rec-image={image}
	data-rec-title={t(titleKey as keyof typeof t)}
	aria-label={`Ver certificado: ${t(titleKey as keyof typeof t)}`}
>
	<div class="relative overflow-hidden">
		<img
			src={image}
			alt={t(titleKey as keyof typeof t)}
			class="w-full aspect-video object-contain p-3 transition-transform duration-300 group-hover:scale-[1.03]"
			loading="lazy"
		/>
		<div
			class="absolute inset-0 flex items-end justify-end p-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200"
		>
			<span
				class="bg-neon text-background font-main text-[10px] px-2 py-0.5 rounded flex items-center gap-1"
			>
				<i class="fas fa-expand" aria-hidden="true"></i>
				<span data-translate="experience.rec.view-certificate">
					{t("experience.rec.view-certificate")}
				</span>
			</span>
		</div>
	</div>
	<div class="px-4 pt-3 pb-4 font-content border-t border-neon/20 flex flex-col gap-0.5">
		<h3 class="font-bold text-neon text-[15px] leading-snug" data-translate={titleKey}>
			{t(titleKey as keyof typeof t)}
		</h3>
		<p class="text-[13px] opacity-75" data-translate={issuerKey}>
			{t(issuerKey as keyof typeof t)}
		</p>
		<small class="text-[12px] opacity-50" data-translate={dateKey}>
			{t(dateKey as keyof typeof t)}
		</small>
	</div>
</button>

<style>
	.recognition-card {
		border-color: color-mix(in srgb, var(--color-neon) 35%, transparent);
		transition:
			border-color 300ms ease-in-out,
			background-color 100ms ease-in-out;
	}
	.recognition-card:hover {
		border-color: color-mix(in srgb, var(--color-neon) 100%, transparent);
		background-color: var(--color-hover);
	}
</style>
