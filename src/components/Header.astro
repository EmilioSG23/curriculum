---
import { useT } from "@/i18n/utils";
import LanguageToogleButton from "@/components/buttons/LanguageToggleButton.astro";
import ThemeToggleButton from "@/components/buttons/ThemeToggleButton.astro";
import Logo from "@/components/Logo.astro";

import { BASE_URL } from "@/config";

const t = useT();

const toPath = (path: string) => {
	return Astro.url.pathname !== BASE_URL ? BASE_URL : path;
};
---

<header class=`text-white sticky top-0 left-0 right-0 z-10 backdrop-blur-[3px]`>
	<nav class="font-main bg-primary/50" aria-label="Navegacion principal">
		<div
			id="mobileContainer"
			class="md:hidden flex flex-wrap px-2 xs:p-2 sm:p-4 justify-between items-center"
		>
			<button
				id="menuButton"
				type="button"
				aria-label="Abrir menu de navegacion"
				aria-controls="menu"
				aria-expanded="false"
				class="p-1 xs:p-2 border border-gold rounded-md scale hover:text-gold transition cursor-pointer"
			>
				<i class="fa fa-bars" aria-hidden="true"></i>
			</button>
			<Logo />
		</div>
		<div
			id="menu"
			class="p-5 gap-4 mx-auto lg:max-w-4xl uppercase
        [&>a]:w-[96px] [&>div#logo]:w-[96px] lg:[&>a]:w-[128px] lg:[&>div#logo]:w-[128px] md:[&>a]:text-[14px] lg:[&>a]:text-[16px]
        justify-between items-center text-center"
		>
			<div id="mobileDesktop" class="hidden md:inline"><ThemeToggleButton /></div>
			<a
				href={toPath("#about-me")}
				data-translate="about-me.title"
				class="hover:md:scale-110 hover:text-gold transition">{t("about-me.title")}</a
			>
			<a
				href={toPath("#projects")}
				data-translate="projects.title"
				class="hover:md:scale-110 hover:text-gold transition">{t("projects.title")}</a
			>

			<div id="logo" class="hidden md:flex justify-center"><Logo /></div>
			<a
				href={toPath("#experience")}
				data-translate="experience.title"
				class="hover:md:scale-110 hover:text-gold transition">{t("experience.title")}</a
			>
			<a
				href={toPath("#skills")}
				data-translate="skills.title"
				class="hover:md:scale-110 hover:text-gold transition">{t("skills.title")}</a
			>

			<div class="self-center"><LanguageToogleButton /></div>
		</div>
	</nav>
	<div
		class="relative bg-gold h-1 left-1/2 -translate-x-1/2 origin-center w-0 animate-border-extension"
	>
	</div>
</header>

<script>
	function moveToggleButton() {
		const mobileContainer = document.getElementById("mobileContainer");
		const mobileDesktop = document.getElementById("mobileDesktop");
		const toggleButton = document.getElementById("theme");
		const parent = window.innerWidth < 768 ? mobileContainer : mobileDesktop;

		if (parent && toggleButton && toggleButton.parentElement !== parent) {
			parent.appendChild(toggleButton);
		}
	}

	function updateActiveSection() {
		const sections = Array.from(document.querySelectorAll<HTMLElement>("section"));
		const anchors = Array.from(document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]'));
		const top = window.scrollY + window.innerHeight * 0.25;

		let activeId = "";
		sections.forEach((section) => {
			if (top >= section.offsetTop && top < section.offsetTop + section.offsetHeight) {
				activeId = section.id;
			}
		});

		anchors.forEach((anchor) => {
			anchor.classList.toggle(
				"active",
				activeId !== "info" && anchor.getAttribute("href") === `#${activeId}`,
			);
		});
	}

	function setupHeaderInteractions() {
		const menu = document.getElementById("menu");
		const menuButton = document.getElementById("menuButton");
		const anchors = Array.from(
			document.querySelectorAll<HTMLAnchorElement>('#menu a, a[href^="#"]'),
		);

		moveToggleButton();
		updateActiveSection();

		menuButton?.addEventListener("click", () => {
			menu?.classList.toggle("open");
			menuButton.setAttribute("aria-expanded", String(menu?.classList.contains("open") ?? false));
		});

		anchors.forEach((anchor) => {
			anchor.onclick = (event) => {
				menu?.classList.remove("open");
				menuButton?.setAttribute("aria-expanded", "false");

				const href = anchor.getAttribute("href");
				if (!href?.startsWith("#")) return;

				event.preventDefault();
				const targetElement = document.getElementById(href.slice(1));
				if (!targetElement) return;

				window.scrollTo({
					top: targetElement.offsetTop - 100,
					behavior: "smooth",
				});
			};
		});
	}

	window.addEventListener("resize", moveToggleButton);
	window.addEventListener("scroll", updateActiveSection, { passive: true });
	document.addEventListener("DOMContentLoaded", setupHeaderInteractions, { once: true });
</script>

<style>
	#menu {
		position: absolute;
		border: solid 2pt var(--color-gold);
		background-color: rgba(0, 0, 0, 0.5);
		display: flex;
		flex-direction: column;
		overflow: hidden;
		max-height: 0;
		opacity: 0;
		visibility: hidden;
		transition:
			max-height 0.3s ease-out,
			opacity 0.3s ease-out,
			visibility 0.3s;
	}

	#menu.open {
		opacity: 1;
		visibility: visible;
		max-height: 250px;
	}

	@media (min-width: 768px) {
		#menu {
			position: initial;
			border: none;
			background-color: transparent;
			display: flex;
			overflow: visible;
			flex-direction: row;
			flex-wrap: wrap;
			max-height: none;
			visibility: visible;
			opacity: 1;
			transition: none;
		}
	}

	#menu.hidden {
		display: none;
	}

	a.active {
		color: var(--color-gold);
	}
</style>
