---

---

<button
	id="theme"
	type="button"
	aria-label="Cambiar tema"
	aria-pressed="true"
	class="text-3xl w-8 h-8 hover:scale-110 hover:text-gold transition cursor-pointer"
>
	<i id="dark" class="fas fa-moon" aria-hidden="true"></i>
	<i id="light" class="fas fa-sun hidden!" aria-hidden="true"></i>
</button>

<script>
	const $sunIcon = document.getElementById("light") as HTMLElement;
	const $moonIcon = document.getElementById("dark") as HTMLElement;
	const $buttonToggle = document.getElementById("theme") as HTMLElement;

	const theme = localStorage.getItem("theme") || "dark";
	const isDark = theme === "dark";

	document.documentElement.classList.toggle("dark", isDark);
	toggleIcon(isDark);

	$buttonToggle.addEventListener("click", () => {
		const $html = document.documentElement;
		const isDark = $html.classList.toggle("dark");
		localStorage.setItem("theme", isDark ? "dark" : "light");
		$buttonToggle.setAttribute("aria-pressed", String(isDark));
		toggleIcon(isDark);
	});

	function toggleIcon(isDark: boolean) {
		$buttonToggle.setAttribute("aria-pressed", String(isDark));
		$sunIcon.classList.toggle("hidden!", isDark);
		$moonIcon.classList.toggle("hidden!", !isDark);
	}
</script>
