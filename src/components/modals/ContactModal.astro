---
import { useT } from "@/i18n/utils";
import { BASE_URL } from "@/config";
import Modal from "./Modal.astro";

const t = useT();
---

<Modal id="contact-modal" ariaLabel={t("contact-form.title")} closeLabel={t("contact-form.close")}>
	<div
		class="w-full max-w-2xl rounded-2xl bg-white
        border border-primary/30 shadow-2xl
        p-8 text-content overflow-y-auto"
	>
		<div class="mb-4">
			<h2
				class="font-title text-3xl text-center font-bold text-primary"
				data-translate="contact-form.title"
			>
				{t("contact-form.title")}
			</h2>

			<span class="mt-2 text-sm opacity-70 text-primary" data-translate="contact-form.description">
				{t("contact-form.description")}
			</span>
		</div>
		<p
			data-contact-error
			class="mb-4 rounded-lg border border-red-300 bg-red-50 px-4 py-3 text-sm text-red-700"
			role="alert"
			hidden
		>
		</p>

		<form action={`${BASE_URL}api/send-contact-me`} method="POST" class="space-y-5">
			<div class="max-h-[40vh] overflow-y-auto flex flex-col gap-2 px-2">
				<div>
					<label class="mb-2 block text-sm font-medium text-primary">
						{t("contact-form.name")}
					</label>

					<input
						type="text"
						name="name"
						required
						placeholder={t("contact-form.name")}
						class="w-full rounded-lg border border-primary/20
                    bg-gray-50/50
                    px-4 py-3 text-black
                    transition-all duration-200
                    outline-none
                    focus:border-primary
                    focus:ring-2 focus:ring-neon/20"
					/>
				</div>

				<div>
					<label class="mb-2 block text-sm font-medium text-primary">
						{t("contact-form.email")}
					</label>

					<input
						type="email"
						name="_replyto"
						required
						placeholder={t("contact-form.email")}
						class="w-full rounded-lg border border-primary/20
                    bg-gray-50/50
                    px-4 py-3 text-black
                    transition-all duration-200
                    outline-none
                    focus:border-primary
                    focus:ring-2 focus:ring-neon/20"
					/>
				</div>

				<div>
					<label class="mb-2 block text-sm font-medium text-primary">
						{t("contact-form.subject")}
					</label>

					<input
						type="text"
						name="subject"
						required
						placeholder={t("contact-form.subject")}
						class="w-full rounded-lg border border-primary/20
                    bg-gray-50/50
                    px-4 py-3 text-black
                    transition-all duration-200
                    outline-none
                    focus:border-primary
                    focus:ring-2 focus:ring-neon/20"
					/>
				</div>

				<div>
					<label class="mb-2 block text-sm font-medium text-primary">
						{t("contact-form.message")}
					</label>

					<textarea
						rows="6"
						name="message"
						required
						placeholder={t("contact-form.message")}
						class="w-full resize-none rounded-lg
                    border border-primary/20
                    bg-gray-50/50
                    px-4 py-3 text-black
                    transition-all duration-200
                    outline-none
                    focus:border-primary
                    focus:ring-2 focus:ring-neon/20"
					></textarea>
				</div>
			</div>

			<button
				type="submit"
				class="mt-4 w-full rounded-lg
                bg-[#5ae1ff] px-5 py-3
                font-semibold text-primary
                transition-all duration-200
                hover:shadow-lg
								hover:bg-gold
                active:scale-100
								cursor-pointer"
			>
				{t("contact-form.send")}
			</button>
		</form>
	</div>
</Modal>

<script>
	const contactModal = document.getElementById("contact-modal") as HTMLDialogElement | null;
	const contactError = contactModal?.querySelector<HTMLElement>("[data-contact-error]");

	const errorKeys = {
		required: "contact-form.error-required",
		"invalid-email": "contact-form.error-email",
		"field-too-long": "contact-form.error-length",
		"email-service": "contact-form.error-service",
		unexpected: "contact-form.error-unexpected",
	} as const;

	const getErrorKey = (reason: string | null) => {
		if (!reason) return errorKeys.unexpected;
		if (reason === "missing-fields") return errorKeys.required;
		if (reason in errorKeys) return errorKeys[reason as keyof typeof errorKeys];
		return "contact-form.error";
	};

	const updateContactError = async (language: string, reason: string | null) => {
		if (!contactError) return;
		const response = await fetch(new URL(`languages/${language}.json`, document.baseURI));
		if (!response.ok) return;

		const texts = await response.json();
		contactError.textContent = texts[getErrorKey(reason)];
	};

	const initializeContactError = () => {
		const params = new URLSearchParams(window.location.search);
		if (params.get("contact") !== "error" || !contactModal || !contactError) return;

		const reason = params.get("reason");
		contactModal.dataset.contactErrorReason = reason || "";
		contactError.hidden = false;
		contactModal.showModal();
		document.body.style.overflow = "hidden";
		void updateContactError(document.documentElement.lang || "es", reason);

		const url = new URL(window.location.href);
		url.searchParams.delete("contact");
		url.searchParams.delete("reason");
		window.history.replaceState({}, "", `${url.pathname}${url.search}${url.hash}`);
	};

	document.addEventListener("languagechange", (event) => {
		const language = (event as CustomEvent<{ language?: string }>).detail?.language;
		if (language !== "es" && language !== "en") return;

		const reason = contactModal?.dataset.contactErrorReason || null;
		void updateContactError(language, reason);
	});

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initializeContactError, { once: true });
	} else {
		initializeContactError();
	}

	contactModal?.addEventListener("close", () => {
		document.body.style.overflow = "";
	});
</script>
