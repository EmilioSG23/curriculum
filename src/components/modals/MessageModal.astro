---
import { useT } from "@/i18n/utils";
import Modal from "./Modal.astro";

const t = useT();
---

<Modal
	id="contact-message-modal"
	ariaLabel={t("contact-form.message-title")}
	closeLabel={t("contact-form.close")}
>
	<div
		data-message-panel
		class="w-[min(90vw,32rem)] rounded-2xl border border-primary/30 bg-white p-8 text-content shadow-2xl"
	>
		<div class="mb-5 flex justify-center" aria-hidden="true">
			<i data-message-icon class="fa-solid text-4xl text-neon"></i>
		</div>
		<h2
			data-message-title
			class="font-title text-center text-3xl font-bold text-primary"
			data-translate="contact-form.success-title"
		>
			{t("contact-form.success-title")}
		</h2>
		<p
			data-message-text
			class="mt-3 text-center text-content"
			data-translate="contact-form.success"
		>
			{t("contact-form.success")}
		</p>
		<button
			type="button"
			data-message-close
			class="mt-7 w-full cursor-pointer rounded-lg bg-[#5ae1ff] px-5 py-3 font-semibold text-primary transition-all duration-200 hover:bg-gold hover:shadow-lg"
			data-translate="contact-form.close"
		>
			{t("contact-form.close")}
		</button>
	</div>
</Modal>

<script>
	const messageModal = document.getElementById("contact-message-modal") as HTMLDialogElement | null;
	const messagePanel = messageModal?.querySelector<HTMLElement>("[data-message-panel]");
	const messageIcon = messageModal?.querySelector<HTMLElement>("[data-message-icon]");
	const messageTitle = messageModal?.querySelector<HTMLElement>("[data-message-title]");
	const messageText = messageModal?.querySelector<HTMLElement>("[data-message-text]");
	const closeButton = messageModal?.querySelector<HTMLButtonElement>("[data-message-close]");

	const messageKeys = {
		success: {
			title: "contact-form.success-title",
			text: "contact-form.success",
			icon: "fa-circle-check",
		},
		error: {
			title: "contact-form.error-title",
			text: "contact-form.error",
			icon: "fa-circle-exclamation",
		},
	} as const;

	const applyTranslations = async (language: string) => {
		const response = await fetch(new URL(`languages/${language}.json`, document.baseURI));
		if (!response.ok) return;

		const texts = await response.json();
		const status = messageModal?.dataset.messageStatus as keyof typeof messageKeys | undefined;
		if (!status) return;

		const keys = messageKeys[status];
		if (messageTitle) messageTitle.textContent = texts[keys.title];
		if (messageText) messageText.textContent = texts[keys.text];
		if (closeButton) closeButton.textContent = texts["contact-form.close"];
	};

	const showMessage = (status: keyof typeof messageKeys) => {
		if (!messageModal || !messagePanel || !messageIcon) return;

		const keys = messageKeys[status];
		messageModal.dataset.messageStatus = status;
		messagePanel.classList.toggle("border-red-400", status === "error");
		messagePanel.classList.toggle("border-primary/30", status === "success");
		messageIcon.className = `fa-solid ${keys.icon} text-4xl ${status === "error" ? "text-red-500" : "text-neon"}`;
		messageModal.showModal();
		document.body.style.overflow = "hidden";

		const url = new URL(window.location.href);
		url.searchParams.delete("contact");
		window.history.replaceState({}, "", `${url.pathname}${url.search}${url.hash}`);
	};

	const initializeMessage = () => {
		const status = new URLSearchParams(window.location.search).get("contact");
		if (status === "success") {
			showMessage("success");
			void applyTranslations(document.documentElement.lang || "es");
		}
	};

	document.addEventListener("languagechange", (event) => {
		const { language } = (event as CustomEvent<{ language: "es" | "en" }>).detail;

		if (language === "es" || language === "en") {
			void applyTranslations(language);
		}
	});

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initializeMessage, { once: true });
	} else {
		initializeMessage();
	}

	messageModal?.addEventListener("close", () => {
		document.body.style.overflow = "";
	});
	closeButton?.addEventListener("click", () => {
		messageModal?.close();
	});
</script>
