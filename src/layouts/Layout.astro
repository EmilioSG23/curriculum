---
import Background from "@/components/Background.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import {
	DEFAULT_SEO,
	getAbsoluteUrl,
	getCanonicalUrl,
	PERSON_SCHEMA,
	SITE_NAME,
	WEBSITE_SCHEMA,
} from "@/utils/seo";
import "@/styles/global.css";

interface Props {
	title?: string;
	description?: string;
	image?: string;
	noindex?: boolean;
	canonical?: string;
}

const {
	title = DEFAULT_SEO.title,
	description = DEFAULT_SEO.description,
	image = DEFAULT_SEO.image,
	noindex = false,
	canonical,
} = Astro.props;

const currentUrl = canonical ?? getCanonicalUrl(Astro.url.pathname);
const pageTitle = title === SITE_NAME ? title : `${title} | ${SITE_NAME}`;
const imageUrl = getAbsoluteUrl(image);
const robots = noindex ? "noindex, nofollow" : "index, follow";
const schemas = JSON.stringify([PERSON_SCHEMA, WEBSITE_SCHEMA]);
---

<!doctype html>
<html lang="es" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/curriculum/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<meta name="robots" content={robots} />
		<meta name="theme-color" content="#000823" />
		<link rel="canonical" href={currentUrl} />

		<meta property="og:type" content={DEFAULT_SEO.type} />
		<meta property="og:locale" content="es_ES" />
		<meta property="og:site_name" content={SITE_NAME} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={currentUrl} />
		<meta property="og:image" content={imageUrl} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl} />
		<script type="application/ld+json" set:html={schemas}></script>
		<script>
			const initScrollAnimations = () => {
				const animatedElements = Array.from(document.querySelectorAll<HTMLElement>("[data-aos]"));
				if (animatedElements.length === 0) return;

				let ticking = false;

				const updateAnimations = () => {
					const triggerLine = window.scrollY + window.innerHeight;

					animatedElements.forEach((element) => {
						const offset = Number(element.dataset.aosOffset || 200);
						const elementTop = element.getBoundingClientRect().top + window.scrollY;
						const isVisible = triggerLine - offset >= elementTop;

						element.classList.add("aos-init");
						element.classList.toggle("aos-animate", isVisible);
					});

					ticking = false;
				};

				const requestUpdate = () => {
					if (ticking) return;
					ticking = true;
					window.requestAnimationFrame(updateAnimations);
				};

				updateAnimations();
				window.addEventListener("scroll", requestUpdate, { passive: true });
				window.addEventListener("resize", requestUpdate);
				document.addEventListener("languagechange", requestUpdate);
			};

			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", initScrollAnimations, { once: true });
			} else {
				initScrollAnimations();
			}
		</script>
	</head>
	<body class="transition">
		<Background />
		<Header />
		<slot />
		<Footer />
	</body>
</html>

<style>
	html {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
