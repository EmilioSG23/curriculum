---
import Background from "@/components/Background.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import {
	DEFAULT_SEO,
	getAbsoluteUrl,
	getCanonicalUrl,
	getLocaleCode,
	getWebsiteSchema,
	PERSON_SCHEMA,
	SITE_BASE_PATH,
	SITE_NAME,
} from "@/utils/seo";
import "@/styles/global.css";
import { BASE_URL } from "@/config";

interface Props {
	title?: string;
	description?: string;
	image?: string;
	noindex?: boolean;
	canonical?: string;
	seoTitleKey?: string;
	seoDescriptionKey?: string;
}

const {
	title = DEFAULT_SEO.title,
	description = DEFAULT_SEO.description,
	image = DEFAULT_SEO.image,
	noindex = false,
	canonical,
	seoTitleKey = "seo.title",
	seoDescriptionKey = "seo.description",
} = Astro.props;

const currentUrl = canonical ?? getCanonicalUrl(Astro.url.pathname);
const pageTitle = title === SITE_NAME ? title : `${SITE_NAME} | ${title}`;
const imageUrl = getAbsoluteUrl(image);
const robots = noindex ? "noindex, nofollow" : "index, follow";
const seoDefaultLanguage = "en";
const schemas = JSON.stringify([PERSON_SCHEMA, getWebsiteSchema(seoDefaultLanguage)]);
---

<!doctype html>
<html lang="es" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={`${BASE_URL}favicon.svg`} />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<meta name="robots" content={robots} />
		<meta name="theme-color" content="#000823" />
		<link rel="canonical" href={currentUrl} />

		<meta property="og:type" content={DEFAULT_SEO.type} />
		<meta property="og:locale" content={getLocaleCode(seoDefaultLanguage)} />
		<meta property="og:site_name" content={SITE_NAME} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={currentUrl} />
		<meta property="og:image" content={imageUrl} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl} />
		<script type="application/ld+json" set:html={schemas} />
		<script
			define:vars={{
				seoBasePath: BASE_URL,
				seoTitleKey,
				seoDescriptionKey,
				seoSiteName: SITE_NAME,
				seoDefaultTitle: pageTitle,
				seoDefaultDescription: description,
				seoPersonSchema: PERSON_SCHEMA,
				seoLocaleMap: { es: getLocaleCode("es"), en: getLocaleCode("en") },
				seoDefaultLanguage,
			}}
		>
			/**
			 * Obtiene el código de idioma a usar para el SEO.
			 * Lee localStorage; si no hay valor guardado, usa el idioma por defecto del servidor.
			 */
			const getSeoLanguage = () => {
				const lang = localStorage.getItem("language") || seoDefaultLanguage;
				return lang in seoLocaleMap ? lang : "es";
			};

			/**
			 * Actualiza de forma dinámica todas las meta-tags SEO y el JSON-LD
			 * para reflejar el idioma activo sin recargar la página.
			 * Se llama al cargar y cada vez que el usuario cambia el idioma.
			 */
			const applySeo = async (language) => {
				const response = await fetch(`${seoBasePath}languages/${language}.json`);
				if (!response.ok) return;

				const texts = await response.json();
				const title = `Emilio Sáenz | ${texts[seoTitleKey] || seoDefaultTitle}`;
				const description = texts[seoDescriptionKey] || seoDefaultDescription;
				const locale = seoLocaleMap[language] || seoLocaleMap.es;
				document.title = title;

				const metaDescription = document.querySelector('meta[name="description"]');
				const metaOgLocale = document.querySelector('meta[property="og:locale"]');
				const metaOgTitle = document.querySelector('meta[property="og:title"]');
				const metaOgDescription = document.querySelector('meta[property="og:description"]');
				const metaTwitterTitle = document.querySelector('meta[name="twitter:title"]');
				const metaTwitterDescription = document.querySelector('meta[name="twitter:description"]');
				const jsonLd = document.querySelector('script[type="application/ld+json"]');

				if (metaDescription) metaDescription.setAttribute("content", description);
				if (metaOgLocale) metaOgLocale.setAttribute("content", locale);
				if (metaOgTitle) metaOgTitle.setAttribute("content", title);
				if (metaOgDescription) metaOgDescription.setAttribute("content", description);
				if (metaTwitterTitle) metaTwitterTitle.setAttribute("content", title);
				if (metaTwitterDescription) metaTwitterDescription.setAttribute("content", description);

				if (jsonLd) {
					jsonLd.textContent = JSON.stringify([
						seoPersonSchema,
						{
							"@context": "https://schema.org",
							"@type": "WebSite",
							name: seoSiteName,
							url: `${window.location.origin}${seoBasePath}`,
							inLanguage: language,
							description,
						},
					]);
				}
			};

			const storedLanguage = localStorage.getItem("language");
			if (storedLanguage === "es" || storedLanguage === "en") {
				document.documentElement.lang = storedLanguage;
			}

			/**
			 * Inicializa las animaciones de scroll basadas en el atributo data-aos.
			 * Usa requestAnimationFrame para no bloquear el hilo principal durante el scroll.
			 * Los elementos se marcan con "aos-animate" cuando cruzan la línea de disparo
			 * (viewport inferior menos el offset configurado por data-aos-offset).
			 */
			const initScrollAnimations = () => {
				const animatedElements = Array.from(document.querySelectorAll("[data-aos]")).filter(
					(element) => element instanceof HTMLElement,
				);
				if (animatedElements.length === 0) return;

				let ticking = false;

				const updateAnimations = () => {
					const triggerLine = window.scrollY + window.innerHeight;

					animatedElements.forEach((element) => {
						const offset = Number(element.dataset.aosOffset || 200);
						const elementTop = element.getBoundingClientRect().top + window.scrollY;
						const isVisible = triggerLine - offset >= elementTop;

						element.classList.add("aos-init");
						element.classList.toggle("aos-animate", isVisible);
					});

					ticking = false;
				};

				const requestUpdate = () => {
					// Evita encolar múltiples frames si el scroll llega antes de que se pinte el anterior.
					if (ticking) return;
					ticking = true;
					window.requestAnimationFrame(updateAnimations);
				};

				updateAnimations();
				window.addEventListener("scroll", requestUpdate, { passive: true });
				window.addEventListener("resize", requestUpdate);
				document.addEventListener("languagechange", requestUpdate);
			};

			// Aplica el SEO del idioma almacenado al cargar la página.
			applySeo(getSeoLanguage());

			// Re-aplica el SEO cuando el usuario cambia el idioma mediante el toggle.
			document.addEventListener("languagechange", (event) => {
				const language = event.detail?.language;
				if (language === "es" || language === "en") {
					applySeo(language);
				}
			});

			// Si el DOM aún está cargando, espera DOMContentLoaded; si ya cargó, ejecuta directamente.
			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", initScrollAnimations, { once: true });
			} else {
				initScrollAnimations();
			}
		</script>
		<Fragment
			set:html={`<style>@font-face{font-family:"JetBrains Mono";font-style:normal;font-weight:400;font-display:swap;src:url("${BASE_URL}fonts/JetBrainsMono-Regular.ttf") format("truetype")}@font-face{font-family:"JetBrains Mono";font-style:italic;font-weight:400;font-display:swap;src:url("${BASE_URL}fonts/JetBrainsMono-Italic.woff2") format("woff2")}@font-face{font-family:"JetBrains Mono";font-style:normal;font-weight:700;font-display:swap;src:url("${BASE_URL}fonts/JetBrainsMono-Bold.ttf") format("truetype")}@font-face{font-family:"Just Another Hand";font-style:normal;font-weight:400;font-display:swap;src:url("${BASE_URL}fonts/JustAnotherHand-Regular.woff2") format("woff2")}</style>`}
		/>
	</head>
	<body class="transition">
		<Background />
		<Header />
		<slot />
		<Footer />
	</body>
</html>

<style>
	html {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
