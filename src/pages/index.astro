---
import AboutMe from "@/features/about-me/AboutMe.astro";
import Experience from "@/features/experience/Experience.astro";
import Info from "@/features/info/Info.astro";
import Projects from "@/features/projects/Projects.astro";
import Skills from "@/features/skills/Skills.astro";
import Layout from "@/layouts/Layout.astro";
import { ui } from "@/i18n/ui";

const seoText = ui.en;

const seo = {
	title: seoText["seo.title"],
	description: seoText["seo.description"],
};
---

<Layout {...seo} seoTitleKey="seo.title" seoDescriptionKey="seo.description">
	<Info />
	<AboutMe />
	<Projects />
	<Experience />
	<Skills />
</Layout>
